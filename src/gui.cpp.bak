#include <QApplication>
#include <QPushButton>
#include <QVBoxLayout>
#include <QWidget>
#include <QLabel>
#include <QTimer>
#include <QDialog>
#include <QProgressBar>
#include <opencv2/opencv.hpp>
#include <QDir>
#include <QInputDialog>
#include <fstream>
#include "facetracker.h"

class CameraControl : public QWidget {
    Q_OBJECT
private:
    cv::VideoCapture cap;
    QTimer* timer;
    QLabel* videoLabel;
    QPushButton* registerButton;
    QPushButton* startButton;
    QPushButton* stopButton;
    FaceTracker* faceTracker;
    bool isCameraRunning;
    std::string model_path;
    std::string config_path;
    std::string feature_model_path;

public:
    CameraControl(QWidget* parent = nullptr)
        : QWidget(parent), isCameraRunning(false),
          model_path("/home/jinwoo/catkin_ws/src/project_ojakdong/src/res10_300x300_ssd_iter_140000_fp16.caffemodel"),
          config_path("/home/jinwoo/catkin_ws/src/project_ojakdong/src/deploy.prototxt"),
          feature_model_path("/home/jinwoo/catkin_ws/src/project_ojakdong/src/feature_model.pth") {

        // 초기 FaceTracker 설정
        if (std::ifstream(feature_model_path)) {
            faceTracker = new FaceTracker(model_path, config_path, feature_model_path, "");
            std::cout << "FaceTracker initialized with feature_model.pth." << std::endl;
        } else {
            faceTracker = nullptr;
            std::cout << "Warning: feature_model.pth not found. Please register a user to create the model." << std::endl;
        }

        // GUI 구성
        QVBoxLayout* layout = new QVBoxLayout(this);
        videoLabel = new QLabel(this);
        videoLabel->setFixedSize(640, 480);
        layout->addWidget(videoLabel);

        startButton = new QPushButton("카메라 시작", this);
        stopButton = new QPushButton("카메라 종료", this);
        registerButton = new QPushButton("사용자 얼굴 등록", this);

        layout->addWidget(startButton);
        layout->addWidget(stopButton);
        layout->addWidget(registerButton);

        timer = new QTimer(this);

        connect(startButton, &QPushButton::clicked, this, &CameraControl::startCamera);
        connect(stopButton, &QPushButton::clicked, this, &CameraControl::stopCamera);
        connect(registerButton, &QPushButton::clicked, this, &CameraControl::startRegistrationMode);
        connect(timer, &QTimer::timeout, this, &CameraControl::updateFrame);
    }

    ~CameraControl() {
        delete faceTracker;
    }

private slots:
    void startCamera() {
        if (!isCameraRunning) {
            cap.open(0); // 기본 카메라 열기
            if (!cap.isOpened()) {
                std::cerr << "카메라를 열 수 없습니다!" << std::endl;
                return;
            }
            isCameraRunning = true;
            timer->start(30);
        }
    }

    void stopCamera() {
        if (isCameraRunning) {
            timer->stop();
            cap.release();
            videoLabel->clear();
            isCameraRunning = false;
        }
    }

    void startRegistrationMode() {
        if (!cap.isOpened()) {
            std::cerr << "카메라가 열리지 않았습니다!" << std::endl;
            return;
        }

        // 사용자 이름 입력 받기
        bool ok;
        QString userName = QInputDialog::getText(this, "사용자 이름 입력", "이름:", QLineEdit::Normal, "", &ok);

        if (!ok || userName.isEmpty()) {
            std::cerr << "사용자 이름 입력이 취소되었습니다." << std::endl;
            return;
        }

        // 저장 디렉토리 설정
        std::string save_dir = "/home/jinwoo/catkin_ws/src/project_ojakdong/src/captured_faces/" + userName.toStdString() + "/";
        QDir().mkpath(QString::fromStdString(save_dir)); // 사용자 이름 기반 디렉토리 생성

        // 등록 모드 창 생성
        QDialog dialog(this);
        dialog.setWindowTitle("사용자 얼굴 등록 - " + userName);
        QLabel* dialogVideoLabel = new QLabel(&dialog);
        dialogVideoLabel->setFixedSize(640, 480);

        QProgressBar* progressBar = new QProgressBar(&dialog); // 진행 상황 표시
        progressBar->setRange(0, 20); // 20개의 이미지 기준
        progressBar->setValue(0);

        QPushButton* captureButton = new QPushButton("캡처", &dialog);
        QPushButton* finishButton = new QPushButton("완료", &dialog);

        QVBoxLayout* dialogLayout = new QVBoxLayout(&dialog);
        dialogLayout->addWidget(dialogVideoLabel);
        dialogLayout->addWidget(progressBar);
        dialogLayout->addWidget(captureButton);
        dialogLayout->addWidget(finishButton);

        QTimer dialogTimer;
        int face_count = 0;

        // 화면 업데이트
        connect(&dialogTimer, &QTimer::timeout, [&]() {
            cv::Mat frame;
            cap >> frame;
            if (!frame.empty()) {
                // ROI 설정 (중앙에 위치, 크기 조정)
                int roiWidth = 600;
                int roiHeight = 600;
                int roiX = (frame.cols - roiWidth) / 2;
                int roiY = (frame.rows - roiHeight) / 2;
                cv::Rect roi(roiX, roiY, roiWidth, roiHeight);

                // ROI 표시
                cv::rectangle(frame, roi, cv::Scalar(255, 0, 0), 2);

                // OpenCV 프레임을 Qt 이미지로 변환
                cv::cvtColor(frame, frame, cv::COLOR_BGR2RGB);
                QImage image(frame.data, frame.cols, frame.rows, frame.step, QImage::Format_RGB888);
                dialogVideoLabel->setPixmap(QPixmap::fromImage(image).scaled(dialogVideoLabel->size(),
                                                                            Qt::KeepAspectRatio, Qt::SmoothTransformation));
            }
        });

        // 캡처 버튼 클릭 이벤트
        connect(captureButton, &QPushButton::clicked, [&]() {
            cv::Mat frame;
            cap >> frame;
            if (!frame.empty()) {
                // ROI 설정
                int roiWidth = 600;
                int roiHeight = 600;
                int roiX = (frame.cols - roiWidth) / 2;
                int roiY = (frame.rows - roiHeight) / 2;
                cv::Rect roi(roiX, roiY, roiWidth, roiHeight);

                // ROI 내 이미지 저장
                cv::Mat faceROI = frame(roi);
                std::string filename = save_dir + "face_" + std::to_string(face_count) + ".jpg";
                cv::imwrite(filename, faceROI);
                face_count++;
                progressBar->setValue(face_count);
                std::cout << "Captured face " << face_count << ": " << filename << std::endl;

                // 20개 이상 캡처 시 완료 버튼 활성화
                if (face_count >= 20) {
                    captureButton->setEnabled(false);
                    finishButton->setEnabled(true);
                }
            }
        });

        // 완료 버튼 클릭 이벤트
        connect(finishButton, &QPushButton::clicked, [&]() {
            dialogTimer.stop();
            dialog.accept();
        });

        // 초기화
        finishButton->setEnabled(false);
        dialogTimer.start(30);
        dialog.exec();

        // 얼굴 등록 완료 후 학습 실행
        std::string command = "python3 /home/jinwoo/catkin_ws/src/project_ojakdong/src/userML.py";
        int result = system(command.c_str());
        if (result == 0) {
            std::cout << "Model training completed successfully!" << std::endl;
        } else {
            std::cerr << "Error during model training." << std::endl;
        }

        // 모델 파일 존재 여부 확인
        if (std::ifstream(feature_model_path)) {
            std::cout << "feature_model.pth found! Reinitializing FaceTracker." << std::endl;
            delete faceTracker;
            faceTracker = new FaceTracker(model_path, config_path, feature_model_path, "");
        } else {
            std::cerr << "Error: feature_model.pth not found after training!" << std::endl;
        }
    }

    void updateFrame() {
        if (cap.isOpened()) {
            cv::Mat frame;
            cap >> frame;
            if (!frame.empty()) {
                std::vector<cv::Rect> faces = faceTracker ? faceTracker->detectFaces(frame) : std::vector<cv::Rect>();
                for (const auto& face : faces) {
                    cv::rectangle(frame, face, cv::Scalar(0, 255, 0), 2);
                }
                cv::cvtColor(frame, frame, cv::COLOR_BGR2RGB);
                QImage image(frame.data, frame.cols, frame.rows, frame.step, QImage::Format_RGB888);
                videoLabel->setPixmap(QPixmap::fromImage(image).scaled(videoLabel->size(),
                                                                       Qt::KeepAspectRatio, Qt::SmoothTransformation));
            }
        }
    }
};

int main(int argc, char* argv[]) {
    QApplication app(argc, argv);

    CameraControl cameraControl;
    cameraControl.setWindowTitle("얼굴 추적기");
    cameraControl.show();

    return app.exec();
}

#include "gui.moc"
